<%# v3.0XXX %>

<div class='title'>Validate Email via Magic Link Failed</div>

<% if @page_from == 'magic-link-email' %>
  <div class='error'>
    <div class='vertical_space_small'></div>
    This link is invalid or has expired - please request a new one
    <div class='vertical_space_small'></div>
  </div>
<% end %>

<%= turbo_frame_tag 'sign_in_failed_turbo_frame' do %>
  <%= render partial: '/hawthorne_core/site_user/partials/sign_in_failed' if @sign_in_failed %>
<% end %>

<div class='form'>

  <%= form_with url: sign_in_path do |f| %>

    <%= hidden_field_tag :page_from, @page_from %>

    <div class='form_input'>
      <label class='form_input'>email address</label>
      <%= f.text_field :email_address, value: @email_address, required: true, maxlength: 320, autofocus: true %>
    </div>

    <div class='form_submit'>
      <%= f.submit 'Continue' %>
    </div>

  <% end %>

</div>

<div class='vertical_space'></div>

<%#= render partial: '/core/site_user/partials/single_sign_on' %>