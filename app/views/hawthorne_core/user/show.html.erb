<%# v3.0 %>

<%
  title = 'My Profile'

  full_name_value = @user.full_name.presence
  email_value = @user.email_address
  phone_number_value = HawthorneCore::Helpers::PhoneNumber.us_format(@user.phone_number).presence
%>

<%= render HawthorneCore::UI::User::LayoutComponent.new(user: @user, title: title) do %>
  <%= render HawthorneCore::UI::User::ProfileAttrComponent.new(label: 'Full Name', value: full_name_value) %>
  <%= render HawthorneCore::UI::User::ProfileAttrComponent.new(label: 'Email', value: email_value) %>
  <%= render HawthorneCore::UI::User::ProfileAttrComponent.new(label: 'Phone Number', value: phone_number_value) %>
<% end %>

<%= render partial: 'hawthorne_core/user/profile/full_name_modal', locals: { modal_element_id: 'profile_full_name_modal' } %>