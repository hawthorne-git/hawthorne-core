<%# v3.0 %>

<div class='title'>Sign-In / Create Account</div>

<%= turbo_frame_tag 'sign_in_failed_turbo_frame' do %>
  <%= render partial: '/hawthorne_core/partials/user/sign_in_failed' if @sign_in_failed %>
<% end %>

<div class='form'>

  <%= form_with url: sign_in_path do |f| %>

    <div class='form_input'>
      <label class='form_input'>email address</label>
      <%= f.text_field :email_address, class: 'form_input', value: 'charlieprezzano@gmail.com', required: true, maxlength: 320, autofocus: true %>
      <div class='vertical_space_very_small'></div>
      <%= f.check_box :keep_signed_in, class: 'form_input' %> Keep me signed in
    </div>

    <div class='form_submit'>
      <%= f.submit 'Continue' %>
    </div>

  <% end %>

</div>

<%= render partial: '/hawthorne_core/partials/user/single_sign_on' %>