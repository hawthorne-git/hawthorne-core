<%# v3.0 %>

<%
  form_url = sign_in_path

  title = 'Continue with email'

  instruction_message = 'Enter your email address. If you already have an account, we’ll sign you in. If not, we’ll create one for you.'

  email_address_label = 'Email'
  email_address_value = 'charlieprezzano@gmail.com' if Rails.env.development?

  submit_button_text = 'Send PIN'
%>

<%= render HawthorneCore::UI::TitleComponent.new(text: title)  %>
<%= render HawthorneCore::UI::Form::FormWrapperComponent.new(instruction_message: instruction_message) do %>
  <%= form_with url: form_url do |f| %>
    <%= render HawthorneCore::UI::Form::HiddenFieldComponent.new(form: f, attribute: :keep_signed_in, value: 1, required: true) %>
    <%= render HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :email_address, label: email_address_label, value: email_address_value, required: true, maxlength: 320) %>
    <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form: f, text: submit_button_text) %>
  <% end %>
<% end %>