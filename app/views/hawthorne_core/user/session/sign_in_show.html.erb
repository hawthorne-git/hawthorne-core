<%# v3.0 %>

<%
  title = 'Sign-In / Create Account'

  email_address_label = 'email address'

  keep_signed_in_text_after_checkbox = 'Keep me signed in'

  submit_button_text = 'Continue'
%>

<%= render HawthorneCore::UI::TitleComponent.new(text: title)  %>

<%= turbo_frame_tag 'sign_in_failed_turbo_frame' do %>
  <%= render partial: 'sign_in_failed' if @sign_in_failed %>
<% end %>

<%= render HawthorneCore::UI::Form::FormWrapperComponent.new do |f| %>
  <%= form_with url: sign_in_path do |f| %>
    <%= render HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :email_address, label: email_address_label, value: 'charlieprezzano@gmail.com', required: true, maxlength: 320) %>
    <%= render HawthorneCore::UI::Form::CheckBoxComponent.new(form: f, attribute: :keep_signed_in, text_after_checkbox: keep_signed_in_text_after_checkbox) %>
    <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form: f, text: submit_button_text) %>
  <% end %>
<% end %>