<%# v3.0 %>

<%= render HawthorneCore::UI::TitleComponent.new(text: 'Sign-In / Create Account')  %>

<%= turbo_frame_tag 'sign_in_failed_turbo_frame' do %>
  <%= render partial: 'sign_in_failed' if @sign_in_failed %>
<% end %>

<%= render HawthorneCore::UI::Form::FormWrapperComponent.new do |f| %>
  <%= form_with url: sign_in_path do |f| %>
    <%= render HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :email_address, label: 'email address', value: 'charlieprezzano@gmail.com', required: true, maxlength: 320) %>
    <%= render HawthorneCore::UI::Form::CheckBoxComponent.new(form: f, attribute: :keep_signed_in, text_after_checkbox: 'Keep me signed in') %>
    <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form: f, text: 'Continue') %>
  <% end %>
<% end %>