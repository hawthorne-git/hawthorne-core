<%# v3.0 %>

<%
  code_delivery_method_via_email = (@code_delivery_method == HawthorneCore::User::CODE_VIA_EMAIL)
  code_delivery_method_via_phone = (@code_delivery_method == HawthorneCore::User::CODE_VIA_PHONE)

  form_url = verify_sign_in_code_path

  title = 'Verify your sign-in code'

  instruction_message = "Enter the 6-digit code we sent to #{@user.email}" if code_delivery_method_via_email
  instruction_message = "Enter the 6-digit code we sent to #{HawthorneCore::Helpers::PhoneNumber.masked(@user.phone_number)}" if code_delivery_method_via_phone

  token_value = @user_token

  code_delivery_method_value = @code_delivery_method

  keep_signed_in_value = @keep_signed_in

  submit_button_text = 'Verify Code'

  resend_code_message = "Didn't get the code? #{link_to 'Resend it', resend_sign_in_code_path(token: @user_token, code_delivery_method: @code_delivery_method, keep_signed_in: @keep_signed_in), data: { turbo: :false }}"
  send_code_via_email_message = "Send code by email instead? #{link_to 'Send email', resend_sign_in_code_via_email_path(token: @user_token, code_delivery_method: @code_delivery_method, keep_signed_in: @keep_signed_in), data: { turbo: :false }}"
  send_code_via_phone_message = "Send code by text message instead? #{link_to 'Send text', resend_sign_in_code_via_text_path(token: @user_token, code_delivery_method: @code_delivery_method, keep_signed_in: @keep_signed_in), data: { turbo: :false }}"
  start_over_message = "Need to change your email? #{link_to 'Start over', sign_in_path, data: { turbo: :false }}"
%>

<%= render HawthorneCore::UI::TitleComponent.new(text: title) %>
<%= render HawthorneCore::UI::Form::FormWrapperComponent.new(instruction_message: instruction_message) do %>
  <%= render partial: '/hawthorne_core/user/verify_code_failed', locals: { expired: @code_expired, max_failed_attempts_reached: @code_max_failed_attempts_reached, not_match: @code_not_match, not_set: @code_not_set } if @verify_code_failed %>
  <%= form_with url: form_url do |f| %>
    <%= render HawthorneCore::UI::Form::HiddenFieldComponent.new(form: f, attribute: :token, value: token_value, required: true) %>
    <%= render HawthorneCore::UI::Form::HiddenFieldComponent.new(form: f, attribute: :code_delivery_method, value: code_delivery_method_value, required: true) %>
    <%= render HawthorneCore::UI::Form::HiddenFieldComponent.new(form: f, attribute: :keep_signed_in, value: keep_signed_in_value) %>
    <%= render HawthorneCore::UI::Form::Attr::CodeTextFieldComponent.new(form: f) %>
    <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form: f, text: submit_button_text) %>
  <% end %>
  <%= render HawthorneCore::UI::Form::SupportMessageComponent.new(message: resend_code_message) %>
  <%= render HawthorneCore::UI::Form::SupportMessageComponent.new(message: send_code_via_email_message) if code_delivery_method_via_phone %>
  <%= render HawthorneCore::UI::Form::SupportMessageComponent.new(message: send_code_via_phone_message) if code_delivery_method_via_email && @user.phone_number.present? %>
  <%= render HawthorneCore::UI::Form::SupportMessageComponent.new(message: start_over_message) if code_delivery_method_via_email %>
<% end %>

<%= render '/hawthorne_core/user/verify_code_auto_submit_js' %>