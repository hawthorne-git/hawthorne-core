<%# v3.0 %>

<%
  form_url = account_profile_sign_in_pin_default_delivery_path

  title = 'Update sign-in PIN default delivery'

  sign_in_pin_default_delivery_label = 'Preferred PIN delivery at sign-in'
  sign_in_pin_default_delivery_options = [['Email', HawthorneCore::User::PIN_VIA_EMAIL], ['Text Message', HawthorneCore::User::PIN_VIA_PHONE]]
  sign_in_pin_default_delivery_options_for_select  = options_for_select(sign_in_pin_default_delivery_options, @sign_in_pin_default_delivery)

  submit_button_text = 'Update Sign-In PIN Delivery'
%>

<%= render HawthorneCore::UI::User::Layout::MyProfileComponent.new(user: @user, title: title) do %>
  <%= render HawthorneCore::UI::Form::FormWrapperComponent.new do %>
    <%= form_with url: form_url do |f| %>
      <%= render HawthorneCore::UI::Form::SelectFieldComponent.new(form: f, attribute: :sign_in_pin_default_delivery, label: sign_in_pin_default_delivery_label, options: sign_in_pin_default_delivery_options_for_select) %>
      <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form: f, text: submit_button_text) %>
    <% end %>
  <% end %>
<% end %>