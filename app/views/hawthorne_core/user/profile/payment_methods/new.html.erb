<%# v3.0 %>

<%
  title = 'Add credit card'
%>

<script src="https://js.stripe.com/v3/"></script>

<%= render HawthorneCore::UI::User::Layout::PaymentMethodsComponent.new(user: @user, title: title) do %>

  <div data-controller="stripe-card"
       data-stripe-card-publishable-key-value="<%= @stripe_publishable_key %>"
       data-stripe-card-client-secret-value="<%= @stripe_setup_intent_client_secret %>">

    <form data-action="submit->stripe-card#submit" class="mt-6 max-w-md">

      <div class="mb-4">
        <label class="block text-sm text-gray-500 mb-1">Card details</label>
        <div data-stripe-card-target="cardElement"
             class="w-full px-4 py-4 border border-gray-300 rounded-xl bg-white"></div>
      </div>

      <div data-stripe-card-target="errors" class="text-red-600 text-sm mb-4"></div>

      <button type="submit"
              data-stripe-card-target="submit"
              class="w-full py-3.5 px-4 bg-brand hover:bg-brand-dark text-white text-base font-semibold rounded-xl transition-colors duration-150 cursor-pointer">
        Save card
      </button>

    </form>

  </div>

<% end %>
