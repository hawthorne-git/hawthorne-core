<%# v3.0 %>

<%
  form_url = account_profile_email_address_verify_pin_path

  title = 'Verify your email'

  instruction_message = "Enter the PIN we sent to #{@new_email_address}"

  submit_button_text = 'Verify and Update Email'

  resend_pin_message = "Didn't get the PIN? #{link_to 'Resend it', account_profile_email_address_resend_pin_path, data: { turbo: :false }}"
%>

<%= render HawthorneCore::UI::User::Layout::MyProfileComponent.new(user: @user, title: title) do %>
  <%= render HawthorneCore::UI::Form::FormWrapperComponent.new(instruction_message: instruction_message) do %>
    <%= form_with url: form_url do |f| %>
      <%= render HawthorneCore::UI::Form::Attr::PinTextFieldComponent.new(form: f) %>
      <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form: f, text: submit_button_text) %>
    <% end %>
    <%= render HawthorneCore::UI::Form::SupportMessageComponent.new(message: resend_pin_message) %>
  <% end %>
<% end %>

<%= render '/hawthorne_core/user/verify_pin_auto_submit_js' %>