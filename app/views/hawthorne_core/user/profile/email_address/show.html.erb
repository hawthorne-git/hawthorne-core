<%# v3.0 %>

<%
  form_url = account_profile_email_address_verify_path

  title = 'Update email address'

  current_email_address_label = 'Current email address'
  current_email_address_value = @user.email_address

  new_email_address_label = 'New email address'

  submit_button_text = 'Send Verification PIN'
%>

<%= render HawthorneCore::UI::User::Layout::MyProfileComponent.new(user: @user, title: title) do %>
  <%= render HawthorneCore::UI::Form::FormWrapperComponent.new do %>
    <%= form_with url: form_url do |f| %>
      <%= render HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :current_email_address, label: current_email_address_label, value: current_email_address_value, disabled: true, required: true, maxlength: 320) %>
      <%= render HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :new_email_address, label: new_email_address_label, required: true, maxlength: 320, autofocus: true) %>
      <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form: f, text: submit_button_text) %>
    <% end %>
  <% end %>
<% end %>