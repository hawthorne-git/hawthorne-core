<%# v3.0 %>

<%
  form_url = account_profile_verify_email_path

  title = 'Update email'

  current_email_label = 'Current email'
  current_email_value = @user.email

  new_email_label = 'New email'

  submit_button_text = 'Send Verification Code'
%>

<%= render HawthorneCore::UI::User::Layout::ProfileComponent.new(user: @user, title: title) do %>
  <%= render HawthorneCore::UI::Form::FormWrapperComponent.new do %>
    <%= form_with url: form_url do |f| %>
      <%= render HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :current_email, label: current_email_label, value: current_email_value, disabled: true, required: true, maxlength: 320) %>
      <%= render HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :new_email, label: new_email_label, required: true, maxlength: 320, autofocus: true) %>
      <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form: f, text: submit_button_text) %>
    <% end %>
  <% end %>
<% end %>