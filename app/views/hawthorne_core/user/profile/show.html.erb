<%# v3.0 %>

<%
  title = 'My profile'

  full_name_value = @user.full_name
  email_value = @user.email_address
  phone_number_value = HawthorneCore::Helpers::PhoneNumber.us_format(@user.phone_number)
%>

<%= render HawthorneCore::UI::User::Layout::MyProfileComponent.new(user: @user, title: title) do %>
  <%= render HawthorneCore::UI::User::ProfileAttrComponent.new(label: 'Full Name', value: full_name_value, modal_element_id: 'profile_full_name_modal') %>
  <%= render HawthorneCore::UI::User::ProfileAttrComponent.new(label: 'Email', value: email_value, url: account_profile_email_address_path) %>
  <%= render HawthorneCore::UI::User::ProfileAttrComponent.new(label: 'Phone Number', value: phone_number_value, url: account_profile_phone_number_path) %>
<% end %>

<%= render partial: 'hawthorne_core/user/profile/full_name_modal', locals: { user: @user, modal_element_id: 'profile_full_name_modal' } %>