<%# v3.0 %>

<%
  form_url = account_profile_full_name_path

  title = 'Edit Full Name'

  full_name_label = 'First Name and Last Name'
  full_name_value = @user.full_name
  full_name_autofocus = @user.full_name.blank?

  submit_button_text = 'Save'
%>

<%= render HawthorneCore::UI::Modal::DialogComponent.new(title: title, modal_element_id: modal_element_id) do %>
  <%= render HawthorneCore::UI::Form::FormWrapperComponent.new do %>
    <%= form_with url: form_url, method: :post do |f| %>
      <%= render HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :full_name, label: full_name_label, value: full_name_value, required: true, autofocus: full_name_autofocus) %>
      <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form: f, text: submit_button_text) %>
    <% end %>
  <% end %>
<% end %>