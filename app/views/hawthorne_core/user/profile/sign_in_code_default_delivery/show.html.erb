<%# v3.0 %>

<%
  url = account_profile_sign_in_code_default_delivery_path

  title = 'Update sign-in code default delivery'

  sign_in_code_default_delivery_label = 'Preferred code delivery at sign-in'
  sign_in_code_default_delivery_options = [['Email', HawthorneCore::User::CODE_VIA_EMAIL], ['Text Message', HawthorneCore::User::CODE_VIA_PHONE]]
  sign_in_code_default_delivery_options_for_select  = options_for_select(sign_in_code_default_delivery_options, @sign_in_code_default_delivery)

  submit_button_text = 'Update Sign-In Code Delivery'
%>

<%= render HawthorneCore::UI::User::Layout::ProfileComponent.new(title:) do %>
  <%= render HawthorneCore::UI::Form::FormWrapperComponent.new do %>
    <%= form_with url: do |form| %>
      <%= render HawthorneCore::UI::Form::SelectFieldComponent.new(form:, attribute: :sign_in_code_default_delivery, label: sign_in_code_default_delivery_label, options: sign_in_code_default_delivery_options_for_select) %>
      <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form:, submit_button_text:) %>
    <% end %>
  <% end %>
<% end %>