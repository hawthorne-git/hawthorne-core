<%# v3.0 %>

<%
  url = account_profile_name_path

  title = "#{@name.blank? ? 'Add' : 'Update'} name"

  name_label = 'First name and Last name'
  name_value = @name
  name_autofocus = @name.blank?

  submit_button_text = "#{@name.blank? ? 'Add' : 'Update'} Name"
%>

<%= render HawthorneCore::UI::User::Layout::ProfileComponent.new(title:) do %>
  <%= render HawthorneCore::UI::Form::FormWrapperComponent.new do %>
    <%= form_with url:, method: :post do |form| %>
      <%= render HawthorneCore::UI::Form::TextFieldComponent.new(form:, attribute: :name, label: name_label, value: name_value, autofocus: name_autofocus) %>
      <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form:, submit_button_text:) %>
    <% end %>
  <% end %>
<% end %>