<%# v3.0 %>

<%
  url = account_profile_delete_account_verify_code_path

  title = 'Delete your account'

  instruction_message = "<b>This action is permanent</b>. Your account will be permanently deleted and cannot be recovered.<br><br>Enter the code we sent to #{@email} to delete your account."

  submit_button_text = 'Delete Account'

  message = "Didn't get the code? #{link_to 'Resend it', account_profile_delete_account_resend_code_path, data: { turbo: :false }}"
%>

<%= render HawthorneCore::UI::User::Layout::ProfileComponent.new(title:) do %>
  <%= render HawthorneCore::UI::Form::FormWrapperComponent.new(instruction_message:) do %>
    <%= form_with url: do |form| %>
      <%= render HawthorneCore::UI::Form::Attr::CodeTextFieldComponent.new(form:) %>
      <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form:, submit_button_text:) %>
    <% end %>
    <%= render HawthorneCore::UI::Form::SupportMessageComponent.new(message:) %>
  <% end %>
<% end %>