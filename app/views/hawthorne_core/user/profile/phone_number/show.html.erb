<%# v3.0 %>

<%
  url = account_profile_verify_phone_number_path

  title = "#{@phone_number.blank? ? 'Add' : 'Update'} phone number"

  instruction_message = "Use your phone number to receive a sign-in code"

  current_phone_number_label = 'Current phone number'
  current_phone_number_value = HawthorneCore::Helpers::PhoneNumber.us_format(phone_number: @phone_number)

  new_phone_number_label = 'Phone number'

  submit_button_text = 'Send Verification Code'

  message = "Currently, we only support US phone numbers. International support is coming soon."
%>

<%= render HawthorneCore::UI::User::Layout::ProfileComponent.new(title:) do %>
  <%= render HawthorneCore::UI::Form::FormWrapperComponent.new(instruction_message:) do %>
    <%= form_with url: do |form| %>
      <%= render HawthorneCore::UI::Form::TextFieldComponent.new(form:, attribute: :current_phone_number, label: current_phone_number_label, value: current_phone_number_value, disabled: true, required: true) if @phone_number.present? %>
      <%= render HawthorneCore::UI::Form::TextFieldComponent.new(form:, attribute: :new_phone_number, label: new_phone_number_label, required: true, autofocus: true) %>
      <%= render HawthorneCore::UI::Form::SubmitButtonComponent.new(form:, submit_button_text:) %>
    <% end %>
    <%= render HawthorneCore::UI::Form::SupportMessageComponent.new(message:) %>
  <% end %>
<% end %>