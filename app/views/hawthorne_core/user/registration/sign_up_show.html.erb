<%# v3.0XXX %>

<div class='title'>Create an Account</div>

<%= turbo_frame_tag 'sign_up_failed_turbo_frame' do %>
  <%= render partial: '/core/user/partials/sign_up_failed' if @sign_up_failed %>
<% end %>

<div class='form'>

  <%= form_with url: sign_up_path do |f| %>

    <div class='form_input'>
      <label class='form_input'>email address</label>
      <%= f.text_field :email_address, value: params[:email_address], required: true, maxlength: 320, autofocus: true %>
    </div>


    <div class='form_input'>
      <label class='form_input'>phone number (optional - us only)</label>
      <%= f.text_field :phone_nbr, value: '', required: false, maxlength: 20 %>
    </div>

    <div class='form_input'>
      <%= f.check_box :keep_signed_in %><label class='form_input' style='display: inline-block; padding-left: 0.25rem; text-transform: none' onclick='document.getElementById("keep_signed_in").checked=true;'>Keep me signed in</label>
    </div>

    <div class='form_submit'>
      <%= f.submit 'Continue' %>
    </div>

  <% end %>

</div>

<%= render partial: '/core/user/partials/single_sign_on' %>

<div class='vertical_space'></div>

<div>
  Already have an account? <%= link_to 'Sign In', sign_in_path %>
</div>