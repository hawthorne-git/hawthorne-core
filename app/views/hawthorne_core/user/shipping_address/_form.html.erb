<%# v3.0 %>

<% add_action = (action == 'add') %>
<% domestic_address = (@selected_country&.code_alpha2 == 'US') %>

<% title_text = "#{action.capitalize} Shipping Address" %>
<%= render(HawthorneCore::UI::TitleComponent.new(text: title_text)) %>

<%= render HawthorneCore::UI::Form::FormWrapperComponent.new do %>

  <% if @select_country %>

    <%= form_with url: add_shipping_address_with_selected_country_path do |f| %>
      <%= render HawthorneCore::UI::Form::Attr::CountrySelectComponent.new(form: f, countries: @ship_to_countries) %>
    <% end %>

  <% else %>

    <% form_url = add_action ? account_add_shipping_address_path : update_shipping_address_path %>
    <%= form_with model: @shipping_address, url: form_url do |f| %>

      <% clear_country_link = link_to 'clear', add_shipping_address_select_country_path, data: { turbo: :false } %>
      <% country_handle_label = "country (#{clear_country_link})" %>
      <%= render(HawthorneCore::UI::Form::HiddenFieldComponent.new(form: f, attribute: :country_code_alpha2, value: @selected_country.code_alpha2, required: true)) %>
      <%= render(HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :country_handle, label: country_handle_label, value: @selected_country.handle, required: true)) %>

      <%= render(HawthorneCore::UI::Form::Attr::AutocompleteAddressComponent.new(form: f, model: @shipping_address, selected_country: @selected_country)) if add_action %>

      <%= render(HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :full_name, label: 'name', value: @shipping_address&.full_name, required: true)) %>

      <%= render(HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :street_address, label: 'street address', value: @shipping_address&.street_address, required: true)) %>

      <%= render(HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :street_address_extended, label: 'apartment, unit, suite, or floor #', value: @shipping_address&.street_address_extended)) %>

      <%= render(HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :city, label: 'city', value: @shipping_address&.city, required: true)) %>

      <% state_province_label = domestic_address ? 'state' : 'state / province / region' %>
      <%= render(HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :state_province, label: state_province_label, value: @shipping_address&.state_province, required: true)) %>

      <% postal_code_label = domestic_address ? 'zip code' : 'postal code' %>
      <%= render(HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :postal_code, label: postal_code_label, value: @shipping_address&.postal_code, required: true)) %>

      <%= render(HawthorneCore::UI::Form::TextFieldComponent.new(form: f, attribute: :phone_number, label: 'phone number - required by select couriers', value: @shipping_address&.phone_number, required: true)) %>

      <% submit_button_text = "#{action.capitalize} Shipping Address" %>
      <%= render(HawthorneCore::UI::Form::SubmitButtonComponent.new(form: f, text: submit_button_text)) %>

    <% end %>

  <% end %>

<% end %>

<% unless @select_country %>
  <%= render partial: '/hawthorne_core/partials/autocomplete_us_address', locals: { element_id_prefix: @shipping_address.model_name.param_key } if domestic_address %>
  <%= render partial: '/hawthorne_core/partials/autocomplete_intl_address', locals: { country_code_alpha3: @selected_country.code_alpha3, element_id_prefix: @shipping_address.model_name.param_key } unless domestic_address %>
<% end %>