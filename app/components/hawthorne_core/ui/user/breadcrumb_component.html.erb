<%# v3.0 %>

<%
  breadcrumb = { text: 'My Profile', url: helpers.account_profile_path } if (@selected_sidebar_navigation_item.downcase == 'my profile' and @title.downcase != @selected_sidebar_navigation_item.downcase)
  breadcrumb = { text: 'Shipping Addresses', url: helpers.account_profile_shipping_addresses_path } if (@selected_sidebar_navigation_item.downcase == 'shipping addresses' and @title.downcase != @selected_sidebar_navigation_item.downcase)
%>

<% if breadcrumb %>
  <div class="max-w-md mx-auto mb-4">
    <%= link_to breadcrumb[:url], class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-brand-heading no-underline hover:no-underline" do %>
      <span>&#8592;</span>
      <span><%= breadcrumb[:text] %></span>
    <% end %>
  </div>
<% end %>