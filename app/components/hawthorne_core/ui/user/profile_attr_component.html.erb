<%# v3.0 %>

<%
  blank_value = '-----'
  @value = @value.presence || blank_value
  @action = (@value == blank_value ? 'Add' : 'Update')
%>

<div class="py-5 border-b border-gray-200 flex items-center justify-between">
  <div>
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1"><%= @label %></p>
    <p class="text-gray-900"><%= @value %></p>
  </div>
  <div class="flex items-center gap-2 text-sm shrink-0">
    <% if @url %>
      <%= link_to @action, @url, data: { turbo: :false }, class: "text-sm text-brand-dark no-underline hover:underline shrink-0 bg-transparent border-none cursor-pointer p-0" %>
      <% if (@label.downcase == 'phone number') && (@action.downcase == 'update') %>
        / <%= link_to 'Remove', helpers.account_profile_phone_number_clear_path, data: { turbo_method: :delete, turbo_confirm: 'Remove your phone number?' }, class: "text-sm text-brand-dark no-underline hover:underline shrink-0 bg-transparent border-none cursor-pointer p-0" %>
      <% end %>
    <% end %>
  </div>
</div>