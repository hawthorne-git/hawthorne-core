<%# v3.0 %>

<%

  # create each navigation component
  addresses_navigation_component = { handle: 'Addresses', url: helpers.account_addresses_path, selected: (@selected_sidebar_navigation_item.downcase == 'addresses') }
  favorites_navigation_component = { handle: 'Favorites', url: helpers.account_favorites_path, selected: (@selected_sidebar_navigation_item.downcase == 'favorites') }
  notifications_navigation_component = { handle: 'Notifications', url: helpers.account_notifications_path, selected: (@selected_sidebar_navigation_item.downcase == 'notifications') }
  orders_navigation_component = { handle: 'Orders', url: helpers.account_orders_path, selected: (@selected_sidebar_navigation_item.downcase == 'orders') }
  payments_navigation_component = { handle: 'Payments', url: helpers.account_payments_path, selected: (@selected_sidebar_navigation_item.downcase == 'payments') }
  profile_navigation_component = { handle: 'Profile', url: helpers.account_profile_path, selected: (@selected_sidebar_navigation_item.downcase == 'profile') }

  # set these navigation components into a list
  navigation_components =
    [
      profile_navigation_component,
      favorites_navigation_component,
      orders_navigation_component,
      notifications_navigation_component,
      addresses_navigation_component,
      payments_navigation_component
    ]

%>

<%# Sidebar %>
<aside class="w-64 shrink-0 border-r border-gray-200 px-6 py-10">

  <%# User greeting %>
  <div class="mb-8">
    <p class="text-lg font-semibold text-brand-heading">Hi, <%= @user.first_name.capitalize if @user.first_name? %></p>
    <p class="text-sm text-gray-500"><%= @user.email %></p>
  </div>

  <%# Navigation %>
  <nav class="flex flex-col gap-1 text-sm">
    <% navigation_components.each do |navigation_component| %>
      <%= render HawthorneCore::UI::User::SidebarNavigationComponent.new(navigation_component: navigation_component) %>
    <% end %>
  </nav>

  <%# Sign out %>
  <div class="mt-10 pt-6 border-t border-gray-200">
    <%= link_to 'Sign Out', helpers.sign_out_path, data: { turbo: :false }, class: "px-3 py-2 text-sm text-gray-500 hover:text-gray-700 no-underline hover:no-underline block" %>
  </div>

</aside>