<%# v3.0 %>

<div class="border border-gray-200 rounded-xl p-5 bg-white flex flex-col mb-4">

  <%# Name %>
  <p class="font-semibold text-gray-900 mb-1"><%= @shipping_address.full_name %></p>

  <%# Street %>
  <p class="text-sm text-gray-600"><%= @shipping_address.street_address %></p>
  <% if @shipping_address.street_address_extended.present? %>
    <p class="text-sm text-gray-600"><%= @shipping_address.street_address_extended %></p>
  <% end %>

  <%# City, State, Zip %>
  <p class="text-sm text-gray-600">
    <%= [@shipping_address.city, @shipping_address.state_province, @shipping_address.postal_code].reject(&:blank?).join(', ') %>
  </p>

  <%# Country (if not US) %>
  <% if @shipping_address.country_code_alpha2 != 'US' %>
    <p class="text-sm text-gray-600"><%= @shipping_address.country_handle %></p>
  <% end %>

  <%# Phone %>
  <% if @shipping_address.phone_number.present? %>
    <p class="text-sm text-gray-600 mt-1"><%= HawthorneCore::Helpers::PhoneNumber.us_format(@shipping_address.phone_number) %></p>
  <% end %>

  <%# Actions %>
  <div class="mt-4 pt-4 border-t border-gray-100 flex items-center gap-4 text-sm">
    <%= link_to 'Edit',
                helpers.account_profile_edit_shipping_address_path(token: @shipping_address.token),
                class: "text-brand-dark no-underline hover:underline" %>
    <%= link_to 'Remove',
                helpers.account_profile_remove_shipping_address_path(token: @shipping_address.token),
                data: { turbo_method: :delete, turbo_confirm: 'Remove this shipping address?' },
                class: "text-brand-dark no-underline hover:underline" %>
  </div>

</div>